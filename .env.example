APP_NAME=flexter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=flexter
# DB_USERNAME=root
# DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# For faster caching with Docker Redis (see docker-compose.yml):
# CACHE_STORE=redis
# REDIS_CLIENT=predis
# REDIS_HOST=redis

# Cache TTLs in seconds (optional — defaults in config/flexter.php)
# FLEXTER_CACHE_CATALOGUE_TTL=1800
# FLEXTER_CACHE_LISTS_TTL=1800
# FLEXTER_CACHE_COMMENTS_TTL=300
# FLEXTER_CACHE_HOME_TTL=600

# Streaming playback (VidPlus default — https://vidplus.to)
FLEXTER_PLAYBACK_ENABLED=true
FLEXTER_PLAYBACK_PROVIDER=vidplus
FLEXTER_PLAYBACK_BASE_URL=https://player.vidplus.to
FLEXTER_PLAYBACK_PROGRESS=session
# VidSrc fallback only:
# FLEXTER_PLAYBACK_PROVIDER=vidsrc
# FLEXTER_PLAYBACK_BASE_URL=https://vidsrc.to
# FLEXTER_PLAYBACK_URL_STYLE=embed
# FLEXTER_PLAYBACK_PROVIDER=vidphantom
# FLEXTER_PLAYBACK_BASE_URL=https://vidphantom.com
# FLEXTER_PLAYBACK_PROGRESS=postmessage
FLEXTER_PLAYBACK_AUTOPLAY=false
FLEXTER_PLAYBACK_AUTONEXT=true
FLEXTER_PLAYBACK_NEXT_BUTTON=true
FLEXTER_PLAYBACK_RESUME=true
FLEXTER_PLAYBACK_SYNC_ACCENT=true
FLEXTER_PLAYBACK_PRIMARY_COLOR=6C63FF
FLEXTER_PLAYBACK_SECONDARY_COLOR=9F9BFF
FLEXTER_PLAYBACK_ICON_COLOR=FFFFFF
FLEXTER_PLAYBACK_POSTER=true
FLEXTER_PLAYBACK_SHOW_TITLE=true
FLEXTER_PLAYBACK_ICONS=default
FLEXTER_PLAYBACK_SERVER_ICON=true
FLEXTER_PLAYBACK_SETTING=true
FLEXTER_PLAYBACK_PIP=true
FLEXTER_PLAYBACK_EPISODE_LIST=true
FLEXTER_PLAYBACK_CHROMECAST=true
FLEXTER_PLAYBACK_WATCHPARTY=false
FLEXTER_PLAYBACK_DOWNLOAD=false
FLEXTER_PLAYBACK_FONT=Roboto
FLEXTER_PLAYBACK_FONT_COLOR=FFFFFF
FLEXTER_PLAYBACK_FONT_SIZE=20
FLEXTER_PLAYBACK_FONT_OPACITY=0.5
# FLEXTER_PLAYBACK_LOGO_URL=
# FLEXTER_PLAYBACK_SERVER=

# Stripe billing (monthly subscription)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Recurring price ID from Stripe Dashboard ($1.99/month product)
STRIPE_PRICE_ID=
BILLING_PLAN_NAME="Flexter Premium"
BILLING_PLAN_DESCRIPTION="Unlimited movie & series streaming"
BILLING_AMOUNT_CENTS=199
BILLING_CURRENCY=usd
CASHIER_CURRENCY=usd

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
